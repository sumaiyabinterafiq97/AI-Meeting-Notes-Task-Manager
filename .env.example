# =============================================================================
# AI Meeting Notes & Task Manager — Environment Variables
# Copy to .env and adjust values for local development
# =============================================================================

# Application
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:3001/api/v1

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meeting_notes
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_notes?schema=public
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/meeting_notes?schema=public

# Authentication
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Additional LLM providers (optional)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=llama3

# LLM routing
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_CHAIN=google,anthropic
LLM_MAX_RETRIES=3
EMBEDDING_MODEL=text-embedding-3-small
WORKSPACE_DAILY_TOKEN_BUDGET=500000

# Email (future)
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com

# Redis (optional — only needed for async BullMQ worker in production)
# REDIS_URL=redis://localhost:6379

# Local dev without Redis/OpenAI: mock AI runs inline in the API
AI_USE_MOCK=true

# Calendar integration (Phase 8)
CALENDAR_USE_MOCK=true
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/v1/calendar/oauth/google/callback
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:3001/api/v1/calendar/oauth/microsoft/callback
CALENDAR_SYNC_LOOKBACK_DAYS=7
CALENDAR_SYNC_LOOKAHEAD_DAYS=30
CALENDAR_REMINDER_GRACE_MINUTES=60
