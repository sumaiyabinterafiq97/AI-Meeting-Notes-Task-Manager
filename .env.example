# =============================================================================
# AI Meeting Notes & Task Manager — Environment Variables
# Copy to .env and adjust values for local development
# =============================================================================

# Application
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:3001/api/v1

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=meeting_notes
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_notes?schema=public
DATABASE_URL_DIRECT=postgresql://postgres:postgres@localhost:5432/meeting_notes?schema=public

# Authentication
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# OpenAI (future)
OPENAI_API_KEY=

# Email (future)
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com

# Redis (optional — only needed for async BullMQ worker in production)
# REDIS_URL=redis://localhost:6379

# Local dev without Redis/OpenAI: mock AI runs inline in the API
AI_USE_MOCK=true
