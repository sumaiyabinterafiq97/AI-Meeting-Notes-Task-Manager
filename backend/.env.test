NODE_ENV=test
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_notes_test?schema=public
JWT_ACCESS_SECRET=test-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=test-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=4
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
AI_USE_MOCK=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
TRANSCRIPTION_PROVIDER=mock
AUDIO_STORAGE_PATH=./storage/audio-test
