generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum MeetingStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
}

enum AiProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ActionItemStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_MENTION
  TASK_DUE_SOON
  TASK_OVERDUE
  INVITATION
  MEETING_PROCESSED
}

// =============================================================================
// Core Models
// =============================================================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  displayName     String    @map("display_name") @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url")
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  workspaceMemberships WorkspaceMember[]
  createdWorkspaces    Workspace[]          @relation("WorkspaceCreator")
  createdMeetings      Meeting[]            @relation("MeetingCreator")
  createdTasks         Task[]               @relation("TaskCreator")
  assignedTasks        Task[]               @relation("TaskAssignee")
  taskStatusChanges    TaskStatusHistory[]  @relation("TaskStatusChanger")
  comments             Comment[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  sentInvitations         WorkspaceInvitation[]  @relation("InvitationSender")
  suggestedActionItems    ActionItemSuggestion[] @relation("SuggestedAssignee")
  notificationPreferences NotificationPreference?

  @@index([email], map: "users_email_idx")
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user")
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_password_reset_user")
  @@map("password_reset_tokens")
}

model Workspace {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  createdBy     User                  @relation("WorkspaceCreator", fields: [createdById], references: [id])
  members       WorkspaceMember[]
  invitations   WorkspaceInvitation[]
  meetings         Meeting[]
  tasks            Task[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  aiProcessingJobs AiProcessingJob[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId], map: "idx_wm_user_id")
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  email       String        @db.VarChar(255)
  role        WorkspaceRole @default(MEMBER)
  tokenHash   String        @unique @map("token_hash") @db.VarChar(255)
  invitedById String        @map("invited_by_id") @db.Uuid
  expiresAt   DateTime      @map("expires_at") @db.Timestamptz
  acceptedAt  DateTime?     @map("accepted_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([workspaceId], map: "idx_workspace_invitations_workspace")
  @@map("workspace_invitations")
}

model Meeting {
  id              String        @id @default(uuid()) @db.Uuid
  workspaceId     String        @map("workspace_id") @db.Uuid
  createdById     String        @map("created_by_id") @db.Uuid
  title           String        @db.VarChar(200)
  meetingDate     DateTime      @map("meeting_date") @db.Timestamptz
  durationMinutes Int?          @map("duration_minutes")
  attendees       Json          @default("[]")
  tags            String[]      @default([])
  agenda          String?
  status          MeetingStatus @default(DRAFT)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz

  workspace   Workspace              @relation(fields: [workspaceId], references: [id])
  createdBy   User                   @relation("MeetingCreator", fields: [createdById], references: [id])
  transcript  MeetingTranscript?
  aiOutput    MeetingAiOutput?
  actionItems      ActionItemSuggestion[]
  tasks            Task[]
  aiProcessingJobs AiProcessingJob[]

  @@index([workspaceId, meetingDate(sort: Desc)], map: "idx_meetings_workspace_date")
  @@map("meetings")
}

model MeetingTranscript {
  id           String   @id @default(uuid()) @db.Uuid
  meetingId    String   @unique @map("meeting_id") @db.Uuid
  content      String
  sourceFormat String   @default("text") @map("source_format") @db.VarChar(20)
  charCount    Int      @map("char_count")
  storageKey   String?  @map("storage_key") @db.VarChar(500)
  uploadedAt   DateTime @default(now()) @map("uploaded_at") @db.Timestamptz

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_transcripts")
}

model MeetingAiOutput {
  id                String             @id @default(uuid()) @db.Uuid
  meetingId         String             @unique @map("meeting_id") @db.Uuid
  summary           String?
  topics            Json               @default("[]")
  decisions         Json               @default("[]")
  risks             Json               @default("[]")
  rawResponse       Json?              @map("raw_response")
  processingStatus  AiProcessingStatus @default(PENDING) @map("processing_status")
  errorMessage      String?            @map("error_message")
  modelVersion      String?            @map("model_version") @db.VarChar(50)
  promptTokens      Int?               @map("prompt_tokens")
  completionTokens  Int?               @map("completion_tokens")
  processedAt       DateTime?          @map("processed_at") @db.Timestamptz
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_ai_outputs")
}

model ActionItemSuggestion {
  id                  String           @id @default(uuid()) @db.Uuid
  meetingId           String           @map("meeting_id") @db.Uuid
  title               String           @db.VarChar(300)
  description         String?
  suggestedAssigneeId String?          @map("suggested_assignee_id") @db.Uuid
  suggestedDueDate    DateTime?        @map("suggested_due_date") @db.Date
  status              ActionItemStatus @default(PENDING)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz

  meeting           Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  suggestedAssignee User?   @relation("SuggestedAssignee", fields: [suggestedAssigneeId], references: [id])
  task              Task?

  @@index([meetingId], map: "idx_action_items_meeting")
  @@map("action_item_suggestions")
}

model AiProcessingJob {
  id             String    @id @default(uuid()) @db.Uuid
  meetingId      String    @map("meeting_id") @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  status         JobStatus @default(PENDING)
  attemptCount   Int       @default(0) @map("attempt_count")
  maxAttempts    Int       @default(3) @map("max_attempts")
  idempotencyKey String?   @unique @map("idempotency_key") @db.VarChar(255)
  bullJobId      String?   @map("bull_job_id") @db.VarChar(255)
  errorMessage   String?   @map("error_message")
  startedAt      DateTime? @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([meetingId], map: "idx_ai_jobs_meeting")
  @@index([status], map: "idx_ai_jobs_status")
  @@map("ai_processing_jobs")
}

model Task {
  id           String       @id @default(uuid()) @db.Uuid
  workspaceId  String       @map("workspace_id") @db.Uuid
  meetingId    String?      @map("meeting_id") @db.Uuid
  actionItemId String?      @unique @map("action_item_id") @db.Uuid
  createdById  String       @map("created_by_id") @db.Uuid
  assigneeId   String?      @map("assignee_id") @db.Uuid
  title       String       @db.VarChar(300)
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date") @db.Date
  position    Int          @default(0)
  completedAt DateTime?    @map("completed_at") @db.Timestamptz
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz

  workspace  Workspace             @relation(fields: [workspaceId], references: [id])
  meeting    Meeting?              @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  actionItem ActionItemSuggestion? @relation(fields: [actionItemId], references: [id], onDelete: SetNull)
  createdBy  User                  @relation("TaskCreator", fields: [createdById], references: [id])
  assignee   User?                 @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments   Comment[]
  statusHistory TaskStatusHistory[]

  @@index([workspaceId, status], map: "idx_tasks_workspace_status")
  @@index([assigneeId, status], map: "idx_tasks_assignee")
  @@map("tasks")
}

model TaskStatusHistory {
  id          String      @id @default(uuid()) @db.Uuid
  taskId      String      @map("task_id") @db.Uuid
  fromStatus  TaskStatus? @map("from_status")
  toStatus    TaskStatus  @map("to_status")
  changedById String      @map("changed_by_id") @db.Uuid
  changedAt   DateTime    @default(now()) @map("changed_at") @db.Timestamptz

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy User @relation("TaskStatusChanger", fields: [changedById], references: [id])

  @@index([taskId], map: "idx_task_status_history_task")
  @@map("task_status_history")
}

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  content   String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId], map: "idx_comments_task_id")
  @@map("comments")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  workspaceId String?          @map("workspace_id") @db.Uuid
  type        NotificationType
  payload     Json             @default("{}")
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_notifications_user")
  @@map("notifications")
}

model NotificationPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  emailTaskAssigned Boolean  @default(true) @map("email_task_assigned")
  emailDueSoon      Boolean  @default(true) @map("email_due_soon")
  inAppMentions     Boolean  @default(true) @map("in_app_mentions")
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  actorId     String   @map("actor_id") @db.Uuid
  action      String   @db.VarChar(50)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)], map: "idx_activity_workspace")
  @@map("activity_logs")
}
